# Copy to .env and fill in. All of these are required at startup (validateEnv)
# except where noted as optional.

# Server
PORT=5000
NODE_ENV=development

# Database (Postgres connection string; add ?sslmode=require for most managed hosts)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Frontend origin (used for CORS + OAuth redirect + email links)
CLIENT_URL=http://localhost:5173

# Backend's own public origin, used to build the Google OAuth callback URL.
# In production set this to your deployed backend URL.
SERVER_URL=http://localhost:3000

# Auth (use long random strings)
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string

# Google OAuth (from Google Cloud console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 (S3-compatible object storage)
R2_REGION=auto
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL that serves uploaded files (R2 public bucket / custom domain)
PUBLIC_FILES_URL=

# Anthropic (AI features). Set a monthly spend cap in the Anthropic console.
ANTHROPIC_API_KEY=

# Email reminders (Gmail SMTP: EMAIL_PASS must be a Google App Password)
EMAIL_USER=
EMAIL_PASS=

# Optional: image search for product photos. App degrades gracefully if unset.
SERPAPI_KEY=
